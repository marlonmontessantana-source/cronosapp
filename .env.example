# Copia este archivo a .env y rellena los valores.

# Entorno
NODE_ENV=production
PORT=3000

# Carpeta de datos (BD SQLite). En el contenedor se monta /data como volumen.
DATA_DIR=/data

# Secreto para firmar los JWT de sesión (cadena aleatoria larga).
JWT_SECRET=cambia-esto-por-una-cadena-larga-aleatoria

# Claves VAPID para notificaciones push.
# Genéralas con:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:marlonmontescomunica@gmail.com
